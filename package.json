{
  "name": "grpc",
  "private": true,
  "license": "BSD 3-Clause",
  "type": "module",
  "workspaces": [
    "packages/**/*"
  ],
  "devDependencies": {
    "@atls/raijin": "0.5.2",
    "@types/node": "22.5.5",
    "typescript": "5.5.4"
  },
  "dependenciesMeta": {
    "@grpc/grpc-js@1.5.5": {
      "unplugged": true
    },
    "grpc_tools_node_protoc_ts@5.2.2": {
      "unplugged": true
    }
  },
  "packageManager": "yarn@4.14.1",
  "formatterIgnorePatterns": [
    "**/*/CHANGELOG.md"
  ],
  "linterIgnorePatterns": [
    "**/*/proto/**/*.js"
  ],
  "typecheckSkipLibCheck": true
}
